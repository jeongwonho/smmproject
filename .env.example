SMM_PANEL_ADMIN_USERNAME=admin
SMM_PANEL_ADMIN_PASSWORD=replace-with-a-strong-password

# Frontend/API split deployment
SMM_PANEL_PUBLIC_API_BASE_URL=https://api.example.com
SMM_PANEL_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
SMM_PANEL_PUBLIC_APP_ORIGIN=https://app.example.com
SMM_PANEL_COOKIE_DOMAIN=.example.com
SMM_PANEL_ADMIN_COOKIE_SAMESITE=Strict
SMM_PANEL_FORCE_SECURE_COOKIES=true

# Future Supabase migration references
# Keep service_role only on the backend.
# SMM_PANEL_SUPABASE_URL=https://your-project.supabase.co
# SMM_PANEL_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
