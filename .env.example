SMM_PANEL_ADMIN_USERNAME=admin
SMM_PANEL_ADMIN_PASSWORD=replace-with-a-strong-password
SMM_PANEL_SESSION_SECRET=replace-with-a-long-random-secret
SMM_PANEL_SECRET_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
CRON_SECRET=replace-with-a-long-random-cron-secret

# Operations notifications
# Sends only Cafe24 supplier dispatch/status failures that already have a supplier mapping.
# SMM_PANEL_SLACK_CAFE24_FAILURE_WEBHOOK_URL=https://hooks.slack.com/services/...

# Frontend/API split deployment
# Leave empty when frontend and backend run in the same Vercel project.
SMM_PANEL_PUBLIC_API_BASE_URL=
SMM_PANEL_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
SMM_PANEL_PUBLIC_APP_ORIGIN=https://app.example.com
SMM_PANEL_COOKIE_DOMAIN=.example.com
SMM_PANEL_ADMIN_COOKIE_SAMESITE=Strict
SMM_PANEL_FORCE_SECURE_COOKIES=true

# Database backend
# Leave empty to keep using local SQLite.
# For Supabase, paste the Postgres connection string from the dashboard or pooler.
# SMM_PANEL_DATABASE_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# Future Supabase service integrations
# Keep anon/service_role keys only on the backend where needed.
# SMM_PANEL_SUPABASE_URL=https://your-project.supabase.co
# SMM_PANEL_SUPABASE_DB_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
# SMM_PANEL_SUPABASE_ANON_KEY=your-anon-key
# SMM_PANEL_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth providers
# Cafe24 Admin API OAuth
# Cafe24 access_token is refreshed automatically while refresh_token is valid.
# If refresh_token expires or app permission is revoked, reconnect from the admin console.
# SMM_PANEL_CAFE24_CLIENT_ID=
# SMM_PANEL_CAFE24_CLIENT_SECRET=
# SMM_PANEL_CAFE24_REDIRECT_URI=https://api.example.com/api/admin/cafe24/oauth/callback
# Cafe24 Developer Center WebHook authentication value sent in X-API-Key.
# SMM_PANEL_CAFE24_WEBHOOK_API_KEY=

# Cafe24 Analyst / GA4 Data API
# Add the service account email to the GA4 property with Viewer permission.
# Private keys can be pasted with literal \n line breaks.
# SMM_PANEL_GA4_PROPERTY_ID=
# SMM_PANEL_GOOGLE_SERVICE_ACCOUNT_EMAIL=
# SMM_PANEL_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Optional until Meta Marketing API spend import is connected.
# Key format can be "source / medium|campaign" or just "campaign".
# SMM_PANEL_META_AD_SPEND_JSON={"facebook / paid|20260702_instamart":{"spend":20000,"clicks":120,"impressions":4000}}

# SMM_PANEL_GOOGLE_CLIENT_ID=
# SMM_PANEL_GOOGLE_CLIENT_SECRET=
# SMM_PANEL_GOOGLE_REDIRECT_URI=https://api.example.com/api/auth/oauth/google/callback
# SMM_PANEL_KAKAO_CLIENT_ID=
# SMM_PANEL_KAKAO_CLIENT_SECRET=
# SMM_PANEL_KAKAO_REDIRECT_URI=https://api.example.com/api/auth/oauth/kakao/callback
# SMM_PANEL_NAVER_CLIENT_ID=
# SMM_PANEL_NAVER_CLIENT_SECRET=
# SMM_PANEL_NAVER_REDIRECT_URI=https://api.example.com/api/auth/oauth/naver/callback

# Public auth email verification
# In local/dev, leave these empty and the API will return a preview code.
# In production, configure a provider before enabling email verification for customers.
# SMM_PANEL_AUTH_EMAIL_PROVIDER=preview
# SMM_PANEL_AUTH_EMAIL_FROM=no-reply@example.com
# SMM_PANEL_AUTH_EMAIL_SENDER_NAME=인스타마트

# Wallet charge / payment
# Public charge page reads only backend-calculated amounts.
# Never expose the secret key or webhook secret to the frontend.
# SMM_PANEL_PAYMENT_PROVIDER=tosspayments
# SMM_PANEL_PAYMENT_PUBLIC_KEY=
# SMM_PANEL_PAYMENT_SECRET_KEY=
# SMM_PANEL_PAYMENT_WEBHOOK_SECRET=
# Production webhooks should send an HMAC SHA-256 signature in X-SMM-Webhook-Signature.
# Set this only for a temporary migration window if a provider cannot send signatures yet.
# SMM_PANEL_ALLOW_LEGACY_WEBHOOK_SECRET=false
# SMM_PANEL_BANK_NAME=
# SMM_PANEL_BANK_ACCOUNT=
# SMM_PANEL_BANK_ACCOUNT_HOLDER=
# SMM_PANEL_BANK_DEPOSIT_GUIDE=
