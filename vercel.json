{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build-static.mjs",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api$", "dest": "/api/index.py?__path=/api" },
    { "src": "/api/(?<path>.*)", "dest": "/api/index.py?__path=/api/$path" },
    { "src": "/admin(?:/.*)?", "dest": "/admin.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
